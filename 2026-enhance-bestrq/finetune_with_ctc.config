from i6_experiments.users.jxu.experiments.ssl.pytorch_networks.ctc_finetune import (
    ConformerCTCModel,
)
from i6_experiments.users.jxu.experiments.ssl.pytorch_networks.ctc_finetune import (
    ConformerCTCConfig,
)
from i6_models.primitives.feature_extraction import LogMelFeatureExtractionV1Config
from i6_models.assemblies.conformer.conformer_rel_pos_v1 import (
    ConformerRelPosEncoderV1Config,
)
from i6_models.parts.frontend.vgg_act import VGG4LayerActFrontendV1Config
from torch.nn.modules.activation import ReLU
from i6_models.parts.frontend.vgg_act import VGG4LayerActFrontendV1
from i6_models.config import ModuleFactoryV1
from i6_models.assemblies.conformer.conformer_rel_pos_v1 import (
    ConformerRelPosBlockV1Config,
)
from i6_models.parts.conformer.feedforward import (
    ConformerPositionwiseFeedForwardV2Config,
)
from torch.nn.modules.activation import SiLU
from i6_models.parts.conformer.mhsa_rel_pos import ConformerMHSARelPosV1Config
from i6_models.parts.conformer.convolution import ConformerConvolutionV2Config
from torch.nn.modules.activation import SiLU
from i6_models_repo.i6_models.parts.conformer.norm import LayerNormNC
from i6_experiments.users.jxu.experiments.ssl.pytorch_networks.ctc_finetune import (
    train_step,
)

cfg = ConformerCTCConfig(
    feature_extraction_cfg=LogMelFeatureExtractionV1Config(
        sample_rate=16000,
        win_size=0.025,
        hop_size=0.01,
        f_min=60,
        f_max=7600,
        min_amp=1e-10,
        num_filters=80,
        center=False,
        n_fft=400,
    ),
    specaug_args={
        "time_min_num_masks": 2,
        "time_max_mask_per_n_frames": 25,
        "time_mask_max_size": 20,
        "freq_min_num_masks": 2,
        "freq_mask_max_size": 5,
        "freq_max_num_masks": 8,
    },
    conformer_cfg=ConformerRelPosEncoderV1Config(
        num_layers=10,
        frontend=ModuleFactoryV1(
            module_class=VGG4LayerActFrontendV1,
            cfg=VGG4LayerActFrontendV1Config(
                in_features=80,
                conv1_channels=32,
                conv2_channels=64,
                conv3_channels=64,
                conv4_channels=32,
                conv_kernel_size=(3, 3),
                conv_padding=None,
                pool1_kernel_size=(1, 2),
                pool1_stride=None,
                pool1_padding=None,
                pool2_kernel_size=(1, 2),
                pool2_stride=(4, 1),
                pool2_padding=None,
                activation=ReLU(),
                out_features=768,
            ),
        ),
        block_cfg=ConformerRelPosBlockV1Config(
            ff_cfg=ConformerPositionwiseFeedForwardV2Config(
                input_dim=768,
                hidden_dim=3072,
                dropout=0.1,
                activation=SiLU(),
                dropout_broadcast_axes=None,
            ),
            mhsa_cfg=ConformerMHSARelPosV1Config(
                input_dim=768,
                num_att_heads=12,
                with_bias=True,
                att_weights_dropout=0.1,
                learnable_pos_emb=False,
                rel_pos_clip=16,
                with_linear_pos=True,
                with_pos_bias=True,
                separate_pos_emb_per_head=True,
                pos_emb_dropout=0.0,
                dropout=0.1,
                dropout_broadcast_axes=None,
            ),
            conv_cfg=ConformerConvolutionV2Config(
                channels=768,
                kernel_size=31,
                dropout=0.1,
                activation=SiLU(),
                norm=LayerNormNC((768,), eps=1e-05, elementwise_affine=True),
                dropout_broadcast_axes=None,
            ),
            modules=["ff", "mhsa", "conv", "ff"],
            scales=[0.5, 1.0, 1.0, 0.5],
        ),
    ),
    final_dropout=0.1,
    target_size=79,
    aux_losses={"10": 1},
)

model_kwargs = {"cfg": cfg}


def get_model(epoch, step, **kwargs):
    return ConformerCTCModel(epoch=epoch, step=step, **model_kwargs, **kwargs)
